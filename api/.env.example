# Dupply API (v1)
PORT=8080
HOST=0.0.0.0
NODE_ENV=development

# SQLite file (dev). Use file:./data/dupply.db or absolute path.
DATABASE_URL=file:./data/dupply.db

# Required for /v1/ramp/* (send header X-Dupply-Api-Key with this value)
DUPPLY_API_KEY=change-me

# Etherfuse FX API — sandbox: https://api.sand.etherfuse.com
# Authorization header is the raw key (no "Bearer " prefix).
ETHERFUSE_BASE_URL=https://api.sand.etherfuse.com
ETHERFUSE_API_KEY=

# Webhook HMAC secret (base64) from POST /ramp/webhook create response — only once.
ETHERFUSE_WEBHOOK_SECRET=
