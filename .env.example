# Dupply API (v1)
PORT=8080
HOST=0.0.0.0
NODE_ENV=development

# Database: SQLite (local default) OR Supabase/Postgres (production / shared dev)
# SQLite:
DATABASE_URL=file:./data/dupply.db
# Supabase (Dashboard → Connect → Session pooler, port 5432 — use when direct host fails with ENETUNREACH / IPv6):
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres
# Example region Ohio: aws-1-us-east-2.pooler.supabase.com (confirm host in your dashboard; may be aws-0 or aws-1)

# Required for /v1/ramp/* (send header X-Dupply-Api-Key with this value)
DUPPLY_API_KEY=change-me

# JWT for /v1/auth/login and Bearer auth on /v1/receivables/* (min 16 chars)
JWT_SECRET=change-me-jwt-secret-at-least-16
# JWT_ACCESS_TTL_SECONDS=3600
# JWT_ISSUER=dupply-backend

# Etherfuse FX API — sandbox: https://api.sand.etherfuse.com
# Authorization header is the raw key (no "Bearer " prefix).
ETHERFUSE_BASE_URL=https://api.sand.etherfuse.com
ETHERFUSE_API_KEY=

# Webhook HMAC secret (base64) from POST /ramp/webhook create response — only once.
ETHERFUSE_WEBHOOK_SECRET=

# Programmatic KYC (sandbox personal auto-approves): npm run etherfuse:kyc-smoke
# ETHERFUSE_KYC_CUSTOMER_ID=       # optional; new UUID if unset
# ETHERFUSE_KYC_WALLET=            # optional Stellar G...
# ETHERFUSE_KYC_SKIP_ORG=1         # if child org already exists

# Smoke: npm run etherfuse:smoke (after KYC — see Etherfuse docs)
# ETHERFUSE_SMOKE_CUSTOMER_ID=
# ETHERFUSE_SMOKE_WALLET_ADDRESS=   # Stellar G... from onboarding (for GET /ramp/assets)
# ETHERFUSE_SMOKE_BANK_ACCOUNT_ID= # UUID passed to onboarding-url (for POST /ramp/order later)
# ETHERFUSE_SMOKE_TARGET_ASSET=    # Optional; default: first CETES from /ramp/assets

# Stellar / Soroban — trade bill registry (crate duplicata-registry; see soroban/DEPLOYMENT-testnet.md)
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
DUPPLY_REGISTRY_CONTRACT_ID=
